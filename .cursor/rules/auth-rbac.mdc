## TypeScript — tipos y verificación de roles

```ts
// src/types/domain.types.ts
export type AppRole = 'admin' | 'provider'

export type UserProfile = {
  id: string
  email: string
  name: string | null
  role: AppRole | null   // null = sin rol asignado
}
```

### Helper de verificación de rol — server side

```ts
// src/lib/auth/roles.ts
import 'server-only'
import { createServerClient } from '@/lib/supabase/server'
import { redirect } from 'next/navigation'
import type { AppRole } from '@/types/domain.types'

export async function getUserRole(): Promise<AppRole | null> {
  const supabase = await createServerClient()
  const { data: { user } } = await supabase.auth.getUser()

  if (!user) return null

  const { data: profile } = await supabase
    .from('users')
    .select('role')
    .eq('id', user.id)
    .single()

  return profile?.role ?? null   // null si no tiene rol — nunca asumir
}

// Proteger rutas que requieren un rol específico
export async function requireRole(role: AppRole): Promise<void> {
  const userRole = await getUserRole()

  if (!userRole) redirect('/unauthorized')           // sin rol → sin acceso
  if (userRole !== role) redirect('/unauthorized')   // rol incorrecto → sin acceso
}

// Proteger rutas que requieren estar logueado (cualquier rol)
export async function requireAuth(): Promise<void> {
  const userRole = await getUserRole()
  if (!userRole) redirect('/unauthorized')
}
```

