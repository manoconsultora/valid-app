## En Server Components y layouts

Usar `notFound()` y `redirect()` de Next.js para errores de navegación. Para el resto, dejar que el `error.tsx` más cercano los capture.

```tsx
// ✅ src/app/posts/[id]/page.tsx
import { notFound } from 'next/navigation'
import { getPost } from '@/services/postsService'
import { createServerClient } from '@/lib/supabase/server'
import { NotFoundError } from '@/services/postsService'

export default async function PostPage({ params }: { params: { id: string } }) {
  const supabase = await createServerClient()

  try {
    const post = await getPost(supabase, params.id)
    return <PostDetail post={post} />
  } catch (error) {
    if (error instanceof NotFoundError) notFound()
    throw error  // dejar que error.tsx lo capture
  }
}
```

