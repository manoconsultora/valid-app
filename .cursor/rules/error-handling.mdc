## En Server Actions

Retornar objetos de resultado tipados — nunca lanzar directamente al cliente.

```ts
// ✅ src/app/posts/actions.ts
"use server"
import { createServerClient } from '@/lib/supabase/server'
import { createPost } from '@/services/postsService'

type ActionResult =
  | { success: true; id: string }
  | { success: false; error: string }

export async function createPostAction(formData: FormData): Promise<ActionResult> {
  try {
    const supabase = await createServerClient()
    const post = await createPost(supabase, {
      title: formData.get('title') as string,
      content: formData.get('content') as string,
    })
    return { id: post.id, success: true }
  } catch (error) {
    return {
      error: error instanceof Error ? error.message : 'Error al crear el post',
      success: false,
    }
  }
}
```

